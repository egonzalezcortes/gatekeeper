# =============================================================================
# Gatekeeper — .gitignore
# =============================================================================

# =============================================================================
# SECRETS — never commit these under any circumstances
# =============================================================================
.env
.env.local
.env.development
.env.production
.env.staging
*.pem
*.key
*.p12
*.pfx

# =============================================================================
# Node.js
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.pnp.*

# =============================================================================
# TypeScript
# =============================================================================
*.tsbuildinfo

# =============================================================================
# Build output
# =============================================================================
dist/
build/
out/
backend/dist/
frontend/dist/
frontend/build/

# =============================================================================
# Docker
# =============================================================================
# Don't ignore docker-compose files — those are committed
# Do ignore local override files
docker-compose.override.yml

# =============================================================================
# Copilot instructions — public repo: never commit this
# =============================================================================
.vscode/settings.json

# Other VSCode files that shouldn't travel with the repo
.vscode/launch.json
.vscode/tasks.json
.vscode/*.code-snippets

# Keep .vscode/ tracked if it has shared settings you want committed
# (in this project, nothing in .vscode/ should be committed)
.vscode/

# =============================================================================
# IDE and editor artifacts
# =============================================================================
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# Testing
# =============================================================================
coverage/
.nyc_output/
jest-results/
test-results/

# =============================================================================
# Logs
# =============================================================================
logs/
*.log

# =============================================================================
# OS artifacts
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# =============================================================================
# Temporary files
# =============================================================================
tmp/
temp/
*.tmp
*.temp